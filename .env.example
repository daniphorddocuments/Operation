PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_DB_HOST:5432/YOUR_DB_NAME
SPRING_DATASOURCE_USERNAME=YOUR_DB_USER
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME
FROMS_STORAGE_VIDEOS_DIR=videos
FROMS_STORAGE_INVESTIGATIONS_DIR=investigations
FROMS_BOOTSTRAP_SEED_DEFAULT_ADMINS=false
FROMS_BOOTSTRAP_ADMIN_USERNAME=
